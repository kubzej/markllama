{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "Markllama",
	"version": "0.1.0",
	"identifier": "io.github.kubzej.markllama",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"title": "Markllama",
				"width": 1100,
				"height": 720,
				"minWidth": 960,
				"minHeight": 480,
				"resizable": true,
				"fullscreen": false,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true,
				"trafficLightPosition": { "x": 16, "y": 32 }
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"android": {
			"debugApplicationIdSuffix": ".debug"
		}
	}
}
